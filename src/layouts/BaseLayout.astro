---
import '../styles/global.css';
import { BLACKOUT_FADE_IN_MS, BLACKOUT_FADE_OUT_MS } from '../constants/terminalLoadAnimation';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

type Props = {
  title: string;
  description?: string;
};

const { title, description = 'Speculative fiction from Refuge — work, bibliography, and contact.' } =
  Astro.props;
const pageTitle = title === 'Refuge' ? 'THE REFUGE' : `${title} · THE REFUGE`;
---

<!doctype html>
<html lang="en" class="bg-refuge-bg text-refuge-fg">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <script is:inline>
      (function () {
        /* Must match TERMINAL_LOAD_STORAGE_KEY in src/constants/terminalLoadAnimation.ts */
        var k = 'refuge-terminal-load-day';
        var pad = function (n) {
          return String(n).padStart(2, '0');
        };
        var d = new Date();
        var day = d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());
        var mode = 'skip';
        try {
          if (localStorage.getItem(k) !== day) mode = 'run';
        } catch (e) {}
        document.documentElement.setAttribute('data-terminal-load', mode);
        if (mode === 'run') {
          document.documentElement.setAttribute('data-terminal-phase', 'empty');
        }
      })();
    </script>
  </head>
  <body class="relative min-h-dvh">
    <div class="grain-overlay" aria-hidden="true"></div>
    <div id="terminal-app-shell" class="relative z-10 flex min-h-dvh flex-col">
      <SiteHeader />
      <main id="main" class="flex-1">
        <slot />
      </main>
      <SiteFooter />
    </div>
    <div
      class="refuge-blackout fixed inset-0 z-[200] flex items-center justify-center bg-black p-4 opacity-0 transition-opacity ease-in-out"
      data-refuge-blackout
      data-refuge-blackout-fade-in-ms={String(BLACKOUT_FADE_IN_MS)}
      data-refuge-blackout-fade-out-ms={String(BLACKOUT_FADE_OUT_MS)}
      hidden
      inert
      aria-hidden="true"
    >
      <p
        class="max-w-[min(100%,42rem)] text-center font-mono text-[10px] uppercase tracking-[0.14em] text-refuge-terminalGreen"
      >
        <span class="text-refuge-terminalGreen" data-refuge-blackout-reestablish></span>
      </p>
    </div>
    <script is:inline>
      (function () {
        function format() {
          try {
            return new Intl.DateTimeFormat(undefined, {
              dateStyle: 'medium',
              timeStyle: 'short',
            }).format(new Date());
          } catch {
            return new Date().toString();
          }
        }

        function isoLocal() {
          var d = new Date();
          function pad(n) {
            return String(n).padStart(2, '0');
          }
          return (
            d.getFullYear() +
            '-' +
            pad(d.getMonth() + 1) +
            '-' +
            pad(d.getDate()) +
            'T' +
            pad(d.getHours()) +
            ':' +
            pad(d.getMinutes()) +
            ':' +
            pad(d.getSeconds())
          );
        }

        function tick() {
          var text = format();
          var iso = isoLocal();
          document.querySelectorAll('[data-refuge-date]').forEach(function (el) {
            el.textContent = text;
          });
          document.querySelectorAll('[data-refuge-datetime]').forEach(function (el) {
            el.setAttribute('datetime', iso);
          });
        }

        tick();
        setInterval(tick, 30000);
      })();
    </script>
    <script>
      import { initTerminalLoad } from '../scripts/terminal-load';
      import { initStableTap } from '../scripts/stable-tap';
      initTerminalLoad();
      initStableTap();
    </script>
    <script is:inline>
      (function () {
        if (typeof console === 'undefined' || !console.log) return;
        /* refuge-terminalGreen — same as Tailwind text-refuge-terminalGreen */
        var terminalGreen = 'color: #4AF626; font-family: ui-monospace, Menlo, Consolas, monospace;';
        console.log(
          'WARNING: UNAUTHORIZED ACCESS TO MUNICIPAL ARCHIVE DETECTED. LOGGING IP ADDRESS...\n\n%c' +
            '         _______________\n' +
            '        /               \\\n' +
            '       /                 \\\n' +
            '      /                   \\\n' +
            '      |   XXXX     XXXX   |\n' +
            '      |   XXXX     XXXX   |\n' +
            '      |   XXX       XXX   |\n' +
            '      |         X         |\n' +
            '      \\__      XXX     __/\n' +
            '        |\\     XXX     /|\n' +
            '        | |           | |\n' +
            '        | I I I I I I I |\n' +
            '        |  I I I I I I  |\n' +
            '         \\_           _/\n' +
            '          \\_         _/\n' +
            '            \\_______/',
          terminalGreen,
        );
      })();
    </script>
  </body>
</html>
