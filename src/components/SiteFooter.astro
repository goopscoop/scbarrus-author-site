---
import ConnectionReadout from './ConnectionReadout.astro';

const year = new Date().getFullYear();
---

<footer class="relative z-10 mt-16 border-t border-refuge-border bg-refuge-surface">
  <div
    class="mx-auto flex max-w-content flex-col gap-4 px-4 py-8 text-sm text-refuge-muted sm:px-5 sm:py-8"
  >
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-refuge-muted">
        © {year} · THE REFUGE
      </p>
      <ConnectionReadout align="end" />
    </div>
    <p class="max-w-measure font-serif text-sm leading-snug">
      Static pages, minimal scripts. No tracking by default—verify your host configuration before launch.
    </p>
  </div>
</footer>
