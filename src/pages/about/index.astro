---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup';
import { site } from '../../data/site';

const mailGeneral = `mailto:${site.contactEmail}?subject=${encodeURIComponent('Inquiry (Refuge site)')}`;
const mailRights = `mailto:${site.contactEmail}?subject=${encodeURIComponent('Rights / events (Refuge site)')}`;
---

<BaseLayout title="About / Contact" description="Bio, contact, and a simple inquiry path.">
  <div class="mx-auto max-w-content px-4 py-12 sm:px-5">
    <div class="grid gap-12 lg:grid-cols-1 lg:items-start">
      <div class="max-w-measure">
        <h1 class="font-mono text-2xl font-semibold tracking-tight sm:text-3xl">{site.authorName}</h1>
        <span class="mt-2 block font-mono text-[11px] text-refuge-muted">WRITER · PEN AND INK ARTIST · SPECULATIVE FICTION</span>

        <div class="mt-8 space-y-6 font-serif text-lg leading-snug text-refuge-fg/95">
          <p>
            Though rumored dead, S.C. Barrus was allegedly witnessed colluding on the project KULT. He is armed with paper and pen, and highly dangerous.
          </p>
          <p>
            He is formerly the writer of The Peculiar Case of the Luminous Eye and Discovering Aberration. Visit <a href="https://scbarrus.com" class="text-refuge-terminal underline decoration-refuge-border underline-offset-4 hover:decoration-refuge-terminal">SCBarrus.com</a> to learn more.
          </p>
        </div>

        <section class="mt-10 rounded-sm border border-refuge-border bg-refuge-surface p-6 shadow-panel" aria-labelledby="contact-heading">
          <h2 id="contact-heading" class="font-mono text-[11px] uppercase tracking-[0.22em] text-refuge-muted">
            Direct line
          </h2>
          <p class="mt-4 font-serif text-base leading-snug text-refuge-fg/95">
            Email:
            <a
              class="font-mono font-semibold text-refuge-terminal underline decoration-refuge-border underline-offset-4 hover:decoration-refuge-terminal"
              href={mailGeneral}
            >
              {site.contactEmail}
            </a>
          </p>
          <p class="mt-3 font-serif text-sm leading-snug text-refuge-muted">
            This site does not run a server-side inbox. Use your mail client; the links below pre-fill a subject line
            to reduce ambiguity.
          </p>
          <ul class="mt-5 grid gap-2 font-mono text-sm">
            <li>
              <a
                class="font-medium text-refuge-fg underline decoration-refuge-border underline-offset-4 hover:text-refuge-terminal hover:decoration-refuge-terminal"
                href={mailGeneral}
              >
                Open general inquiry
              </a>
            </li>
            <li>
              <a
                class="font-medium text-refuge-fg underline decoration-refuge-border underline-offset-4 hover:text-refuge-terminal hover:decoration-refuge-terminal"
                href={mailRights}
              >
                Open rights / events
              </a>
            </li>
          </ul>
        </section>
      </div>

      <NewsletterSignup client:visible />
    </div>
  </div>
</BaseLayout>
