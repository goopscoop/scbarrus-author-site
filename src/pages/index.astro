---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup';
import kultCover from '../assets/kult_cover.jpg';
import { books } from '../data/books';
import { site } from '../data/site';

const projects = [
  {
    name: 'Discovering Aberration',
    href: '/books/discovering-aberration',
    note: 'Novel — expedition, obsession, and what surfaces when the map lies.',
    type: 'NOVEL',
    archiveId: '001',
  },
  {
    name: 'The Peculiar Case of the Luminous Eye',
    href: '/books/the-peculiar-case-of-the-luminous-eye',
    note: 'Novel — a case file that will not stay closed.',
    type: 'NOVEL',
    archiveId: '002',
  },
  {
    name: 'The Refuge Logs',
    href: '/logs',
    note: 'Work in progress — fragments, research, and figure studies.',
    type: 'WIP_LOG',
    archiveId: '003',
  },
];
---

<BaseLayout
  title="Refuge"
  description="Speculative fiction author site — books, work-in-progress logs, and contact."
>
  <div class="mx-auto max-w-content px-4 py-12 sm:px-5">
    <div class="border-l-2 border-refuge-border pl-5">
      <h1 class="font-mono text-2xl font-semibold tracking-tight text-refuge-fg sm:text-3xl">
        {site.authorName}
      </h1>
      <div
        class="mt-3 flex flex-col gap-6 sm:mt-4 sm:flex-row sm:items-start sm:gap-6 md:gap-8"
      >
        <p class="min-w-0 max-w-[min(100%,34rem)] flex-1 font-serif text-lg leading-snug text-refuge-fg/95 sm:text-xl">
          {site.positioning}
          <br />
          <br />
          <span class="font-mono text-refuge-terminal">KULT</span><br />
          <span class="font-mono text-refuge-terminalGreen">STATUS: IN DEVELOPMENT</span>
          <br />
          A supernatural dystopia set in Refuge, Earth's final decaying outpost. Kult investigates
          a reality-altering anomaly in a crumbling society completely severed from the rest of
          humanity.
        </p>
        <div class="mx-auto w-full max-w-[10rem] shrink-0 sm:mx-0 sm:max-w-[12rem] md:max-w-[13.5rem]">
          <Image
            src={kultCover}
            alt="Novel cover art"
            class="h-auto w-full max-h-[min(52vh,24rem)] rounded-sm object-contain object-top shadow-panel"
            sizes="(min-width: 640px) 12rem, 100vw"
            loading="eager"
            fetchpriority="high"
          />
          <p class="mt-4 font-mono text-sm font-medium text-refuge-terminal">Read the first chapter →</p>
        </div>
      </div>
    </div>

    <section class="mt-14" aria-labelledby="projects-heading">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <h2 id="projects-heading" class="font-mono text-[11px] uppercase tracking-[0.22em] text-refuge-muted">
          Active files
        </h2>
        <p class="max-w-measure font-serif text-sm leading-snug text-refuge-muted">
          Three threads: two published novels and an open work-in-progress log.
        </p>
      </div>

      <ul class="mt-6 grid gap-4 sm:grid-cols-1">
        {
          projects.map((p) => (
            <li class="rounded-sm border border-refuge-border bg-refuge-surface p-5 shadow-panel">
              <dl class="grid gap-1 font-mono text-[10px] uppercase tracking-[0.14em] text-refuge-muted sm:grid-cols-2">
                <div class="flex gap-2">
                  <dt class="text-refuge-muted/80">Type</dt>
                  <dd class="text-refuge-fg/90">{p.type.replaceAll('_', ' ')}</dd>
                </div>
                <div class="flex gap-2 sm:justify-end">
                  <dt class="text-refuge-muted/80">Archive_id</dt>
                  <dd class="text-refuge-terminal">{p.archiveId}</dd>
                </div>
              </dl>
              <a
                href={p.href}
                class="mt-4 block rounded-sm focus-visible:outline-none"
              >
                <h3 class="font-mono text-base font-semibold leading-snug text-refuge-fg hover:text-refuge-terminal">
                  {p.name}
                </h3>
              </a>
              <p class="mt-3 font-serif text-sm leading-snug text-refuge-fg/90">{p.note}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14 grid gap-6 lg:grid-cols-1 lg:items-start">
      <div class="rounded-sm border border-refuge-border bg-refuge-surface p-6 shadow-panel">
        <h2 class="font-mono text-[11px] uppercase tracking-[0.22em] text-refuge-muted">Shelf snapshot</h2>
        <ul class="mt-4 divide-y divide-refuge-border">
          {
            books.map((b) => (
              <li class="py-4 first:pt-0">
                <a href={`/books/${b.slug}`} class="group block rounded-sm focus-visible:outline-none">
                  <dl class="mb-2 flex flex-wrap gap-x-4 gap-y-1 font-mono text-[10px] uppercase tracking-[0.12em] text-refuge-muted">
                    <div class="flex gap-1.5">
                      <dt class="text-refuge-muted/75">Type</dt>
                      <dd class="text-refuge-fg/85">Novel</dd>
                    </div>
                    <div class="flex gap-1.5">
                      <dt class="text-refuge-muted/75">Archive_id</dt>
                      <dd class="text-refuge-terminal">{b.archiveId}</dd>
                    </div>
                  </dl>
                  <p class="font-mono text-sm font-semibold text-refuge-fg group-hover:text-refuge-terminal">
                    {b.title}
                    {b.year ? <span class="font-normal text-refuge-muted"> · {b.year}</span> : null}
                  </p>
                  <p class="mt-2 font-serif text-sm leading-snug text-refuge-fg/90">{b.description}</p>
                </a>
              </li>
            ))
          }
        </ul>
        <p class="mt-5">
          <a
            href="/bookshelf"
            class="font-mono text-sm font-medium text-refuge-terminal underline decoration-refuge-border underline-offset-4 hover:decoration-refuge-terminal"
          >
            Open the bookshelf
          </a>
        </p>
      </div>

      <NewsletterSignup client:visible />
    </section>
  </div>
</BaseLayout>
