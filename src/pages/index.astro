---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup';
import kultCover from '../assets/kult_cover.jpg';

function logSlugFromId(id: string): string {
  return (id.split('/').pop() ?? id).replace(/\.mdx?$/i, '');
}

const recentLogs = (
  await getCollection('logs', ({ data, id }) => {
    if (data.draft) return false;
    if (logSlugFromId(id).toLowerCase().startsWith('example')) return false;
    return true;
  })
)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Refuge"
  description="Speculative fiction author site — books, work-in-progress logs, and contact."
>
  <div class="mx-auto max-w-content px-4 py-12 sm:px-5">
    <div class="border-l-2 border-refuge-border pl-5">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:gap-6 md:gap-8">
        <div class="min-w-0 flex-1 flex flex-col gap-6">
          <div>
            <h1 class="font-mono text-2xl font-semibold tracking-tight sm:text-3xl text-refuge-terminal">
              KULT
            </h1>
            <span class="mb-4 block font-mono text-[11px]">STATUS: <span class="text-refuge-terminalGreen">IN DEVELOPMENT</span></span>
            <p class="font-serif text-lg leading-snug text-refuge-fg/95 sm:text-xl">
              A supernatural dystopia set in Refuge, Earth's final decaying outpost. Kult investigates
              a reality-altering anomaly in a crumbling society completely severed from the rest of
              humanity.
            </p>
          </div>
          <p>
            <a
              href="/logs/01-kult-chapter-01"
              class="inline-block border border-refuge-terminal px-7 py-3 font-mono text-[0.82rem] uppercase tracking-[0.19em] text-refuge-terminal no-underline transition-colors duration-200 ease-in-out hover:bg-refuge-terminal hover:text-zinc-900"
            >Read the first chapter</a>
          </p>
        </div>
        <div class="mx-auto w-full max-w-[10rem] shrink-0 sm:mx-0 sm:max-w-[12rem] md:max-w-[13.5rem]">
          <Image
            src={kultCover}
            alt="Novel cover art"
            class="h-auto w-full max-h-[min(52vh,24rem)] rounded-sm object-contain object-top shadow-panel"
            sizes="(min-width: 640px) 12rem, 100vw"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>

    <section class="mt-14" aria-labelledby="recent-logs-heading">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <h2 id="recent-logs-heading" class="font-mono text-[11px] uppercase tracking-[0.22em] text-refuge-muted">
          Recent logs
        </h2>
        <p class="max-w-measure font-serif text-sm leading-snug text-refuge-muted">
          Latest entries from the Refuge Logs.
        </p>
      </div>

      <ul class="mt-6 grid gap-4 sm:grid-cols-1">
        {
          recentLogs.map((entry) => {
            const slug = logSlugFromId(entry.id);
            const dateStr = entry.data.date.toISOString().slice(0, 10);
            return (
            <li class="rounded-sm border border-refuge-border bg-refuge-surface p-5 shadow-panel">
              <dl class="grid gap-1 font-mono text-[10px] uppercase tracking-[0.14em] text-refuge-muted sm:grid-cols-2">
                <div class="flex gap-2">
                  <dt class="text-refuge-muted/80">Type</dt>
                  <dd class="text-refuge-fg/90">LOG</dd>
                </div>
                <div class="flex gap-2 sm:justify-end">
                  <dt class="text-refuge-muted/80">Date</dt>
                  <dd class="text-refuge-terminal">{dateStr}</dd>
                </div>
              </dl>
              <a
                href={`/logs/${slug}`}
                class="mt-4 block rounded-sm focus-visible:outline-none"
              >
                <h3 class="font-mono text-base font-semibold leading-snug text-refuge-fg hover:text-refuge-terminal">
                  {entry.data.title}
                </h3>
              </a>
              {entry.data.summary ? (
                <p class="mt-3 font-serif text-sm leading-snug text-refuge-fg/90">{entry.data.summary}</p>
              ) : null}
            </li>
            );
          })
        }
      </ul>
    </section>

    <section class="mt-14">
      <NewsletterSignup client:visible />
    </section>
  </div>
</BaseLayout>
