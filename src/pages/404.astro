---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="The requested path is not in this archive.">
  <div class="mx-auto max-w-content px-4 py-16 sm:px-5">
    <div class="max-w-measure rounded-sm border border-refuge-border bg-refuge-surface p-8 shadow-panel">
      <h1 class="font-mono text-2xl font-semibold">404 — missing file</h1>
      <p class="mt-3 font-serif text-base leading-snug text-refuge-fg/90">
        That route is not available. Return to the index and continue from there.
      </p>
      <p class="mt-6">
        <a
          class="font-mono text-sm font-medium text-refuge-terminal underline decoration-refuge-border underline-offset-4 hover:decoration-refuge-terminal"
          href="/"
        >
          Open home
        </a>
      </p>
    </div>
  </div>
</BaseLayout>
