---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { books, displayBookType } from '../../data/books';
import { coverByFilename } from '../../data/coverAssets';
---


<BaseLayout title="Bookshelf" description="Published novels — summaries and retailer links.">
  <div class="mx-auto max-w-content px-4 py-12 sm:px-5">
    <header class="max-w-measure">
      <h1 class="font-mono text-2xl font-semibold tracking-tight sm:text-3xl">Bookshelf</h1>

    </header>

    <ul class="mt-10 grid gap-5 sm:grid-cols-1">
      {
        books.map((book) => {
          const cover = coverByFilename[book.img];
          return (
            <li class="rounded-sm border border-refuge-border bg-refuge-surface shadow-panel">
              <div class="flex h-full gap-4 p-6 sm:gap-5">
                {cover ? (
                  <a
                    href={`/books/${book.slug}`}
                    class="shrink-0 self-start rounded-sm focus-visible:outline-none"
                    aria-label={`Open dossier: ${book.title}`}
                  >
                    <Image
                      src={cover}
                      alt={`Cover: ${book.title}`}
                      class="h-auto w-[4.5rem] rounded-sm border border-refuge-border bg-refuge-elevated object-cover shadow-panel sm:w-[5.5rem]"
                      widths={[88, 128, 176]}
                      sizes="(min-width: 640px) 5.5rem, 4.5rem"
                      loading="lazy"
                      decoding="async"
                    />
                  </a>
                ) : null}
                <div class="min-w-0 flex-1 flex flex-col">
                  <a
                    href={`/books/${book.slug}`}
                    class="group block rounded-sm focus-visible:outline-none"
                  >
                    <dl class="flex flex-wrap gap-x-5 gap-y-1 font-mono text-[10px] uppercase tracking-[0.12em] text-refuge-muted">
                      <div class="flex gap-1.5">
                        <dt class="text-refuge-muted/75">Type</dt>
                        <dd class="text-refuge-fg/85">{displayBookType(book.type)}</dd>
                      </div>
                      <div class="flex gap-1.5">
                        <dt class="text-refuge-muted/75">Archive_id</dt>
                        <dd class="text-refuge-terminal">{book.archiveId}</dd>
                      </div>
                    </dl>
                    <h2 class="mt-2 font-mono text-lg font-semibold leading-snug text-refuge-fg group-hover:text-refuge-terminal">
                      {book.title}
                      {book.year ? <span class="font-normal text-refuge-muted"> · {book.year}</span> : null}
                    </h2>
                    <p class="mt-4 font-serif text-sm leading-snug text-refuge-fg/90">{book.description}</p>
                  </a>
                  <p class="mt-3">
                    <a
                      href={book.amazonUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 rounded-sm font-mono text-sm font-medium text-refuge-terminalGreen underline decoration-refuge-border underline-offset-4 hover:decoration-refuge-terminalGreen"
                    >
                      Buy on Amazon
                      <span class="font-mono text-[11px] text-refuge-terminalGreen/70">↗</span>
                    </a>
                  </p>
                </div>
              </div>
            </li>
          );
        })
      }
    </ul>
  </div>
</BaseLayout>
