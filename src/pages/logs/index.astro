---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('logs', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout
  title="The Refuge Logs"
  description="Work in progress — dated entries, notes, and image-ready sketch slots."
>
  <div class="mx-auto max-w-content px-4 py-12 sm:px-5">
    <header class="max-w-measure">
      <h1 class="font-mono text-2xl font-semibold tracking-tight sm:text-3xl">The Refuge Logs</h1>
      <p class="mt-3 font-serif text-lg leading-snug text-refuge-fg/95">
        A work-in-progress index. Add new Markdown files under <span class="font-mono text-sm text-refuge-muted"
          >src/content/logs/</span
        >; images belong in <span class="font-mono text-sm text-refuge-muted">public/</span> and are referenced from
        frontmatter.
      </p>
    </header>

    <ol class="mt-12 divide-y divide-refuge-border border-t border-refuge-border">
      {
        entries.map((entry) => (
          <li class="py-8">
            <article class="grid gap-6 lg:grid-cols-[220px_1fr] lg:items-start">
              <div>
                <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-refuge-muted">Entry</p>
                <p class="mt-2 font-mono text-xs text-refuge-muted">
                  {entry.data.date.toISOString().slice(0, 10)}
                </p>
                {entry.data.tags?.length ? (
                  <ul class="mt-3 flex flex-wrap gap-2">
                    {entry.data.tags.map((t) => (
                      <li class="rounded-sm border border-refuge-border bg-refuge-surface px-2 py-1 font-mono text-[11px] text-refuge-muted">
                        {t}
                      </li>
                    ))}
                  </ul>
                ) : null}
              </div>

              <div class="min-w-0">
                <h2 class="font-mono text-xl font-semibold tracking-tight">
                  <a class="text-refuge-fg hover:text-refuge-terminal" href={`/logs/${entry.slug}`}>
                    {entry.data.title}
                  </a>
                </h2>
                {entry.data.summary ? (
                  <p class="mt-3 font-serif text-base leading-snug text-refuge-fg/90">{entry.data.summary}</p>
                ) : null}
                <p class="mt-4">
                  <a
                    class="font-mono text-sm font-medium text-refuge-terminal underline decoration-refuge-border underline-offset-4 hover:decoration-refuge-terminal"
                    href={`/logs/${entry.slug}`}
                  >
                    Open entry
                  </a>
                </p>
              </div>
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</BaseLayout>
