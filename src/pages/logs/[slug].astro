---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('logs', ({ data }) => !data.draft);
  return entries.map((entry) => {
    const tail = entry.id.split('/').pop() ?? entry.id;
    const slug = tail.replace(/\.mdx?$/i, '');
    return { params: { slug }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.summary ?? entry.data.title}>
  <article class="mx-auto max-w-content px-4 py-12 sm:px-5">
    <header class="max-w-measure border-b border-refuge-border pb-8">
      <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-refuge-muted">Refuge log</p>
      <h1 class="mt-3 font-mono text-3xl font-semibold tracking-tight sm:text-4xl">{entry.data.title}</h1>
      <p class="mt-4 font-mono text-sm text-refuge-muted">{entry.data.date.toISOString().slice(0, 10)}</p>
      {entry.data.tags?.length ? (
        <ul class="mt-4 flex flex-wrap gap-2" aria-label="Tags">
          {entry.data.tags.map((t: string) => (
            <li class="rounded-sm border border-refuge-border bg-refuge-surface px-2 py-1 font-mono text-[11px] text-refuge-muted">
              {t}
            </li>
          ))}
        </ul>
      ) : null}
    </header>

    {entry.data.image ? (
      <figure class="mt-10 max-w-measure">
        <img
          src={entry.data.image}
          alt={entry.data.imageAlt ?? ''}
          loading="lazy"
          decoding="async"
          class="w-full rounded-sm border border-refuge-border bg-refuge-surface"
        />
        {entry.data.imageAlt ? (
          <figcaption class="mt-3 font-serif text-sm leading-snug text-refuge-muted">{entry.data.imageAlt}</figcaption>
        ) : null}
      </figure>
    ) : null}

    <div
      class:list={[
        'prose prose-invert max-w-measure prose-headings:font-mono prose-headings:tracking-tight prose-p:font-serif prose-p:text-base prose-p:leading-snug prose-li:font-serif prose-li:leading-snug prose-a:text-refuge-terminal prose-a:no-underline hover:prose-a:underline',
        entry.data.image ? 'mt-10' : 'mt-10',
      ]}
    >
      <Content />
    </div>

    <nav class="mt-12 border-t border-refuge-border pt-8" aria-label="Log navigation">
      <a
        class="font-mono text-sm font-medium text-refuge-terminal hover:underline"
        href="/logs"
      >
        ← Return to logs index
      </a>
    </nav>
  </article>
</BaseLayout>
